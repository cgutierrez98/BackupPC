<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LocalBackupMaster.ViewModels"
             xmlns:m="clr-namespace:LocalBackupMaster.Models"
             x:Class="LocalBackupMaster.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Local Backup Master"
             BackgroundColor="{StaticResource PageBgLight}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="25" MaximumWidthRequest="1200" HorizontalOptions="Fill">

            <!-- Header -->
            <VerticalStackLayout HorizontalOptions="Center" Margin="0,0,0,10">
                <Label x:Name="HeaderTitle"
                       Text="Local Backup Master"
                       FontFamily="OpenSansSemibold"
                       FontSize="36"
                       TextColor="#1D1D1F"
                       HorizontalOptions="Center"/>
                <Label Text="Copia de seguridad local incremental, sin nube."
                       FontSize="16" TextColor="#6B7280"
                       HorizontalOptions="Center"
                       x:Name="SubHeaderLabel"/>
            </VerticalStackLayout>

            <!-- Dashboard Grid -->
            <Grid ColumnDefinitions="*, 420" ColumnSpacing="25" RowDefinitions="Auto" HorizontalOptions="Fill">

                <!-- ══════ COLUMNA IZQUIERDA: GESTIÓN DE DATOS ══════ -->
                <VerticalStackLayout Grid.Column="0" Spacing="20">

                    <!-- Orígenes Card -->
                    <Border x:Name="SourcesCard"
                            StrokeThickness="0" BackgroundColor="{StaticResource SurfaceLight}"
                            Padding="22">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="📁  Carpetas de Origen" FontFamily="OpenSansSemibold" FontSize="17"
                                       TextColor="{StaticResource CardTitleLight}" VerticalOptions="Center"/>
                                <Button Grid.Column="1" Text="+ Añadir" FontSize="13" CornerRadius="8"
                                    BackgroundColor="{StaticResource AccentBlue}" TextColor="White" HeightRequest="36"
                                    Clicked="OnSelectSourceClicked" x:Name="SelectSourceBtn"/>
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource DividerLight}"/>

                            <CollectionView x:Name="SourcesCollectionView" ItemsSource="{Binding SourceItems}"
                                            SelectionMode="None" MinimumHeightRequest="60" MaximumHeightRequest="220">
                                <CollectionView.EmptyView>
                                    <VerticalStackLayout HorizontalOptions="Center" Padding="0,16" Spacing="6">
                                        <Label Text="📂" FontSize="28" HorizontalTextAlignment="Center"/>
                                        <Label Text="Sin carpetas de origen" FontSize="13"
                                               TextColor="{StaticResource SubtextLight}"
                                               HorizontalTextAlignment="Center"/>
                                    </VerticalStackLayout>
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="m:BackupSource">
                                        <Grid ColumnDefinitions="*, Auto" Padding="0,6">
                                            <Label Grid.Column="0" Text="{Binding Path}" FontSize="13"
                                                   TextColor="{StaticResource BodyLight}"
                                                   LineBreakMode="TailTruncation" VerticalOptions="Center"/>
                                            <Button Grid.Column="1" Text="✕" FontSize="13" WidthRequest="44" HeightRequest="44"
                                                    CornerRadius="10" BackgroundColor="Transparent"
                                                    TextColor="Gray"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveSourceCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Destinos Card -->
                    <Border x:Name="DestsCard"
                            StrokeThickness="0" BackgroundColor="{StaticResource SurfaceLight}"
                            Padding="22">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="💾  Destinos de Backup" FontFamily="OpenSansSemibold" FontSize="17"
                                       TextColor="{StaticResource CardTitleLight}" VerticalOptions="Center"/>
                                <Button Grid.Column="1" Text="+ Añadir" FontSize="13" CornerRadius="8"
                                    BackgroundColor="{StaticResource AccentBlue}" TextColor="White" HeightRequest="36"
                                    Clicked="OnSelectDestinationClicked" x:Name="SelectDestinationBtn"/>
                            </Grid>
                            <BoxView HeightRequest="1" Color="#EBEBEB"/>

                            <CollectionView x:Name="DestsCollectionView" ItemsSource="{Binding DestinationItems}"
                                            SelectionMode="None" MinimumHeightRequest="50" MaximumHeightRequest="160">
                                <CollectionView.EmptyView>
                                    <VerticalStackLayout HorizontalOptions="Center" Padding="0,12" Spacing="6">
                                        <Label Text="💽" FontSize="24" HorizontalTextAlignment="Center"/>
                                        <Label Text="Sin destinos registrados" FontSize="13"
                                               TextColor="{StaticResource SubtextLight}"
                                               HorizontalTextAlignment="Center"/>
                                    </VerticalStackLayout>
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="m:BackupDestination">
                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10" Padding="0,6">
                                            <Label Grid.Column="0" Text="💽" FontSize="18" VerticalOptions="Center"/>
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                                <Label Text="{Binding BackupPath}" FontSize="13"
                                                   TextColor="{StaticResource BodyLight}"
                                                   LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding Uuid}" FontSize="10" TextColor="{StaticResource SubtextLight}"
                                                       LineBreakMode="TailTruncation"/>
                                            </VerticalStackLayout>
                                            <Button Grid.Column="2" Text="✕" FontSize="13" WidthRequest="44" HeightRequest="44"
                                                    CornerRadius="10" BackgroundColor="Transparent"
                                                    TextColor="Gray"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveDestinationCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ══════ COLUMNA DERECHA: CONTROL Y ESTADO ══════ -->
                <VerticalStackLayout Grid.Column="1" Spacing="20">

                    <!-- Perfiles Card (C1) -->
                    <Border StrokeThickness="0" BackgroundColor="{StaticResource SurfaceLight}"
                            Padding="22">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                        <VerticalStackLayout Spacing="12">
                            <Label Text="🗂  Perfiles" FontFamily="OpenSansSemibold" FontSize="17"
                                   TextColor="{StaticResource CardTitleLight}"/>

                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                <Entry Grid.Column="0"
                                       Text="{Binding NewProfileName}"
                                       Placeholder="Nombre del perfil..."
                                       FontSize="13"
                                       BackgroundColor="#F8F9FA"/>
                                <Button Grid.Column="1" Text="💾 Guardar"
                                        Command="{Binding SaveProfileCommand}"
                                        FontSize="12" CornerRadius="8"
                                        BackgroundColor="{StaticResource AccentBlue}" TextColor="White" HeightRequest="40"/>
                            </Grid>

                            <CollectionView ItemsSource="{Binding Profiles}" SelectionMode="None"
                                            MaximumHeightRequest="120">
                                <CollectionView.EmptyView>
                                    <Label Text="Sin perfiles guardados" FontSize="12" Opacity="0.5"
                                           TextColor="{StaticResource SubtextLight}"
                                           HorizontalTextAlignment="Center" Padding="0,8"/>
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="m:BackupProfile">
                                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="6" Padding="0,4">
                                            <Label Grid.Column="0" Text="{Binding Name}" FontSize="13" VerticalOptions="Center"
                                                   TextColor="{StaticResource BodyLight}"/>
                                            <Button Grid.Column="1" Text="Cargar" FontSize="11" HeightRequest="32"
                                                    CornerRadius="6" Padding="8,0"
                                                    BackgroundColor="#E1E4E8" TextColor="#24292E"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=LoadProfileCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            <Button Grid.Column="2" Text="✕" FontSize="11" HeightRequest="32" WidthRequest="32"
                                                    CornerRadius="6" BackgroundColor="Transparent" TextColor="Gray"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DeleteProfileCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Button Text="📋 Ver historial"
                                    Command="{Binding NavigateToHistoryCommand}"
                                    FontSize="13" CornerRadius="8" HeightRequest="38"
                                    BackgroundColor="#E1E4E8" TextColor="#24292E"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Control de Backup Card -->
                    <Border x:Name="ConfigCard"
                            StrokeThickness="0" BackgroundColor="{StaticResource SurfaceLight}"
                            Padding="22">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                        <VerticalStackLayout Spacing="15">
                            <Label Text="⚡  Control de Backup" FontFamily="OpenSansSemibold" FontSize="17"
                                   TextColor="{StaticResource CardTitleLight}"/>

                            <!-- Filtro de Extensiones -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Filtrar Contenido" FontSize="13" TextColor="{StaticResource SubtextLight}"/>
                                <FlexLayout Wrap="Wrap" JustifyContent="Start">
                                    <FlexLayout.Resources>
                                        <Style TargetType="Button">
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="HeightRequest" Value="36"/>
                                            <Setter Property="Margin" Value="0,0,8,8"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="CornerRadius" Value="14"/>
                                            <Setter Property="BackgroundColor" Value="#E1E4E8"/>
                                            <Setter Property="TextColor" Value="#24292E"/>
                                        </Style>
                                    </FlexLayout.Resources>
                                    <Button Text="Todo" Command="{Binding ToggleFilterCommand}" CommandParameter="all">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsAllActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}"/>
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <Button Text="📷 Fotos" Command="{Binding ToggleFilterCommand}" CommandParameter="photos">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsPhotosActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}"/>
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <Button Text="Docs" Command="{Binding ToggleFilterCommand}" CommandParameter="docs">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsDocsActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}"/>
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <Button Text="🎥 Video" Command="{Binding ToggleFilterCommand}" CommandParameter="video">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsVideoActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}"/>
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <Button Text="🎵 Audio" Command="{Binding ToggleFilterCommand}" CommandParameter="audio">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsAudioActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}"/>
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </FlexLayout>
                                <Entry Text="{Binding IncludeExtensions}" Placeholder="Filtros manuales..." FontSize="12" BackgroundColor="#F8F9FA"/>
                            </VerticalStackLayout>

                            <!-- Paralelismo -->
                            <VerticalStackLayout Spacing="4">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="Hilos paralelos" FontSize="13" TextColor="{StaticResource SubtextLight}" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding ParallelDegree}" FontFamily="OpenSansSemibold" TextColor="{StaticResource AccentBlue}" FontSize="16"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="6">
                                    <Label Grid.Column="0" Text="1" FontSize="11" TextColor="{StaticResource SubtextLight}" VerticalOptions="Center"/>
                                    <Slider Grid.Column="1" Minimum="1" Maximum="8" Value="{Binding ParallelDegree}" MinimumTrackColor="{StaticResource AccentBlue}"/>
                                    <Label Grid.Column="2" Text="8" FontSize="11" TextColor="{StaticResource SubtextLight}" VerticalOptions="Center"/>
                                </Grid>
                            </VerticalStackLayout>

                            <!-- A2 — Throttle -->
                            <VerticalStackLayout Spacing="4">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="Throttle (KB/s)" FontSize="13" TextColor="{StaticResource SubtextLight}" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource AccentBlue}">
                                        <Label.Text>
                                            <Binding Path="DestinationItems[0].ThrottleKBps" FallbackValue="0" StringFormat="{}{0} KB/s"/>
                                        </Label.Text>
                                    </Label>
                                </Grid>
                                <Label Text="0 = sin límite" FontSize="10" Opacity="0.5" TextColor="{StaticResource SubtextLight}"/>
                            </VerticalStackLayout>

                            <!-- A3 — Filtro por fecha -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                <CheckBox Grid.Column="0" IsChecked="{Binding UseSinceDate}" Color="{StaticResource AccentBlue}"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <Label Text="Solo archivos desde:" FontSize="13" TextColor="{StaticResource SubtextLight}"/>
                                    <DatePicker Date="{Binding SinceDate}" IsEnabled="{Binding UseSinceDate}" FontSize="12"/>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- A1 — Dry-Run -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsDryRun}" Color="{StaticResource AccentBlue}"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="🔍 Modo Simulacro (Dry-Run)" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource BodyLight}"/>
                                    <Label Text="Analiza qué se copiaría, sin copiar nada." FontSize="11" Opacity="0.6" TextColor="{StaticResource SubtextLight}"/>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Botones Iniciar/Cancelar -->
                            <Button Text="🚀 Iniciar Backup" Command="{Binding StartBackupCommand}" Clicked="OnStartBackupClicked"
                                    IsEnabled="{Binding CanStartBackup}"
                                    CornerRadius="10" BackgroundColor="{StaticResource AccentBlue}" TextColor="White" HeightRequest="48" Margin="0,5,0,0"/>
                            <Button Text="Cancelar" Command="{Binding CancelBackupCommand}" Clicked="OnCancelBackupClicked"
                                    IsVisible="{Binding CanCancel}" CornerRadius="10" BackgroundColor="{StaticResource ErrorRed}" TextColor="White" HeightRequest="44"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Progreso Card -->
                    <Border x:Name="ProgressCard" IsVisible="False" Opacity="0" Scale="0.95"
                            StrokeThickness="0" BackgroundColor="{StaticResource SurfaceLight}"
                            Padding="22">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="20" Opacity="0.1"/></Border.Shadow>

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <ProgressBar Progress="{Binding GlobalProgress}" ProgressColor="{StaticResource AccentBlue}" HeightRequest="8" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding PercentageText}" FontFamily="OpenSansSemibold" FontSize="20" TextColor="{StaticResource AccentBlue}" Margin="10,0,0,0"/>
                            </Grid>
                            <Label Text="{Binding CurrentFileStatus}" FontSize="11" TextColor="{StaticResource SubtextLight}" LineBreakMode="TailTruncation" HorizontalOptions="Center"/>
                            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="8">
                                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                                    <Label Text="ESCANEADOS" FontSize="8" TextColor="{StaticResource SubtextLight}" HorizontalTextAlignment="Center"/>
                                    <Label x:Name="StatScannedValue" Text="{Binding StatsScanned}" FontSize="14" HorizontalTextAlignment="Center" TextColor="{StaticResource AccentBlue}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                                    <Label Text="COPIADOS" FontSize="8" TextColor="{StaticResource SubtextLight}" HorizontalTextAlignment="Center"/>
                                    <Label x:Name="StatCopiedValue" Text="{Binding StatsCopied}" FontSize="14" HorizontalTextAlignment="Center" TextColor="{StaticResource SuccessGreen}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                                    <Label Text="FALLOS" FontSize="8" TextColor="{StaticResource SubtextLight}" HorizontalTextAlignment="Center"/>
                                    <Label x:Name="StatFailedValue" Text="{Binding StatsFailed}" FontSize="14" HorizontalTextAlignment="Center" TextColor="{StaticResource ErrorRed}"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Consola de Actividad -->
                    <Border x:Name="ConsoleCard" IsVisible="{Binding ShowActivityLog}" StrokeThickness="0"
                            BackgroundColor="{StaticResource ConsoleBgLight}"
                            Padding="15" HeightRequest="250">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="LOG DE ACTIVIDAD" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource ConsoleAccent}" Margin="0,0,0,5"/>
                            <CollectionView ItemsSource="{Binding LogItems}" HeightRequest="206">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LogEntry">
                                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10" Padding="0,1">
                                            <Label Grid.Column="0" Text="{Binding Timestamp}" TextColor="#666" FontSize="10" FontFamily="Consolas"/>
                                            <Label Grid.Column="1" Text="{Binding Message}" TextColor="{Binding Color}" FontSize="10" FontFamily="Consolas" LineBreakMode="NoWrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LocalBackupMaster.ViewModels"
             xmlns:m="clr-namespace:LocalBackupMaster.Models"
             x:Class="LocalBackupMaster.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Local Backup Master"
             BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#0A0A0A}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="25" MaximumWidthRequest="1200" HorizontalOptions="Center">

            <!-- Header -->
            <VerticalStackLayout HorizontalOptions="Center" Margin="0,0,0,10">
                <Label x:Name="HeaderTitle"
                       Text="Local Backup Master"
                       FontFamily="OpenSansSemibold"
                       FontSize="36"
                       TextColor="{AppThemeBinding Light=#1D1D1F, Dark=#F5F5F7}"
                       HorizontalOptions="Center"
                       Opacity="0" TranslationY="-20" />

                  <Label Text="Copia de seguridad local incremental, sin nube."
                      FontSize="16" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                       HorizontalOptions="Center"
                       Opacity="0" x:Name="SubHeaderLabel"/>
            </VerticalStackLayout>

            <!-- Dashboard Grid -->
            <Grid ColumnDefinitions="*, 420" ColumnSpacing="25" RowDefinitions="Auto">
                
                <!-- ══════ COLUMNA IZQUIERDA: GESTIÓN DE DATOS ══════ -->
                <VerticalStackLayout Grid.Column="0" Spacing="20">
                    
                    <!-- Orígenes Card -->
                    <Border x:Name="SourcesCard" Opacity="0" TranslationY="30"
                            StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                            Padding="22">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="📁  Carpetas de Origen" FontFamily="OpenSansSemibold" FontSize="17"
                                       TextColor="{AppThemeBinding Light=#222, Dark=#EEE}" VerticalOptions="Center"/>
                                <Button Grid.Column="1" Text="+ Añadir" FontSize="13" CornerRadius="8"
                                    BackgroundColor="#0078D4" TextColor="White" HeightRequest="36"
                                    Clicked="OnSelectSourceClicked" x:Name="SelectSourceBtn"
                                    AutomationProperties.Name="Añadir carpeta de origen"
                                    AutomationProperties.HelpText="Abre el diálogo para seleccionar una carpeta de origen."/>
                            </Grid>
                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EBEBEB, Dark=#2E2E2E}"/>

                            <CollectionView x:Name="SourcesCollectionView" ItemsSource="{Binding SourceItems}"
                                            SelectionMode="None" EmptyView="Sin carpetas de origen."
                                            HeightRequest="200">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="m:BackupSource">
                                        <Grid ColumnDefinitions="*, Auto" Padding="0,6">
                                            <Label Grid.Column="0" Text="{Binding Path}" FontSize="13"
                                                   TextColor="{AppThemeBinding Light=#444, Dark=#BBB}"
                                                   LineBreakMode="TailTruncation" VerticalOptions="Center"/>
                                                            <Button Grid.Column="1" Text="✕" FontSize="13" WidthRequest="44" HeightRequest="44"
                                                                    CornerRadius="10" BackgroundColor="Transparent"
                                                                    TextColor="Gray" 
                                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveSourceCommand}"
                                                                    CommandParameter="{Binding .}"
                                                                    AutomationProperties.Name="Eliminar carpeta de origen"
                                                                    AutomationProperties.HelpText="Elimina esta carpeta de la lista de orígenes."/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Destinos Card -->
                    <Border x:Name="DestsCard" Opacity="0" TranslationY="30"
                            StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                            Padding="22">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="💾  Destinos de Backup" FontFamily="OpenSansSemibold" FontSize="17"
                                       TextColor="{AppThemeBinding Light=#222, Dark=#EEE}" VerticalOptions="Center"/>
                                <Button Grid.Column="1" Text="+ Añadir" FontSize="13" CornerRadius="8"
                                    BackgroundColor="#0078D4" TextColor="White" HeightRequest="36"
                                    Clicked="OnSelectDestinationClicked" x:Name="SelectDestinationBtn"
                                    AutomationProperties.Name="Añadir destino de backup"
                                    AutomationProperties.HelpText="Abre el diálogo para seleccionar un destino de backup."/>
                            </Grid>
                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EBEBEB, Dark=#2E2E2E}"/>

                            <CollectionView x:Name="DestsCollectionView" ItemsSource="{Binding DestinationItems}"
                                            SelectionMode="None" EmptyView="Sin destinos registrados."
                                            HeightRequest="150">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="m:BackupDestination">
                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10" Padding="0,6">
                                            <Label Grid.Column="0" Text="💽" FontSize="18" VerticalOptions="Center"/>
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                                <Label Text="{Binding BackupPath}" FontSize="13"
                                                       TextColor="{AppThemeBinding Light=#444, Dark=#BBB}"
                                                       LineBreakMode="TailTruncation"/>
                                                      <Label Text="{Binding Uuid}" FontSize="10" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                                       LineBreakMode="TailTruncation"/>
                                            </VerticalStackLayout>
                                                     <Button Grid.Column="2" Text="✕" FontSize="13" WidthRequest="44" HeightRequest="44"
                                                         CornerRadius="10" BackgroundColor="Transparent"
                                                         TextColor="Gray" 
                                                         Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveDestinationCommand}"
                                                         CommandParameter="{Binding .}"
                                                         AutomationProperties.Name="Eliminar destino de backup"
                                                         AutomationProperties.HelpText="Elimina este destino de la lista."/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ══════ COLUMNA DERECHA: CONTROL Y ESTADO ══════ -->
                <VerticalStackLayout Grid.Column="1" Spacing="20">
                    
                    <!-- Acciones Card -->
                    <Border x:Name="ConfigCard" Opacity="0" TranslationY="30"
                            StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                            Padding="22">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                        <VerticalStackLayout Spacing="15">
                            <Label Text="⚡  Control de Backup" FontFamily="OpenSansSemibold" FontSize="17"
                                   TextColor="{AppThemeBinding Light=#222, Dark=#EEE}"/>
                            
                            <!-- Filtro de Extensiones -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Filtrar Contenido" FontSize="13" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"/>
                                <FlexLayout Wrap="Wrap" JustifyContent="Start">
                                    <FlexLayout.Resources>
                                        <Style TargetType="Button">
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="HeightRequest" Value="36"/>
                                            <Setter Property="Margin" Value="0,0,8,8"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="CornerRadius" Value="14"/>
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E1E4E8, Dark=#30363D}"/>
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#24292E, Dark=#C9D1D9}"/>
                                        </Style>
                                    </FlexLayout.Resources>
                                    <Button Text="Todo" Command="{Binding ToggleFilterCommand}" CommandParameter="all" AutomationProperties.Name="Mostrar todo" AutomationProperties.HelpText="Muestra todos los tipos de archivo en el filtro.">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsAllActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#0078D4"/><Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <Button Text="📷 Fotos" Command="{Binding ToggleFilterCommand}" CommandParameter="photos" AutomationProperties.Name="Filtrar fotos" AutomationProperties.HelpText="Filtra para copiar únicamente fotos.">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsPhotosActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#0078D4"/><Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <Button Text="Docs" Command="{Binding ToggleFilterCommand}" CommandParameter="docs" AutomationProperties.Name="Filtrar documentos" AutomationProperties.HelpText="Filtra para copiar únicamente documentos.">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsDocsActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#0078D4"/><Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <Button Text="🎥 Video" Command="{Binding ToggleFilterCommand}" CommandParameter="video" AutomationProperties.Name="Filtrar vídeos" AutomationProperties.HelpText="Filtra para copiar únicamente vídeos.">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsVideoActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#0078D4"/><Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <Button Text="🎵 Audio" Command="{Binding ToggleFilterCommand}" CommandParameter="audio" AutomationProperties.Name="Filtrar audio" AutomationProperties.HelpText="Filtra para copiar únicamente archivos de audio.">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsAudioActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#0078D4"/><Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </FlexLayout>
                                    <Entry Text="{Binding IncludeExtensions}" Placeholder="Filtros manuales..." FontSize="12" BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2C2C2E}"
                                        AutomationProperties.Name="Filtros manuales" AutomationProperties.HelpText="Escriba extensiones o patrones separados por comas."/>
                            </VerticalStackLayout>

                            <!-- Paralelismo -->
                            <VerticalStackLayout Spacing="4">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="Hilos paralelos" FontSize="13" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding ParallelDegree}" FontFamily="OpenSansSemibold" TextColor="#0078D4" FontSize="16"/>
                                </Grid>
                                <Slider Minimum="1" Maximum="8" Value="{Binding ParallelDegree}" MinimumTrackColor="#0078D4"/>
                            </VerticalStackLayout>

                            <!-- Iniciar/Cancelar -->
                                <Button Text="🚀 Iniciar Backup" Command="{Binding StartBackupCommand}" Clicked="OnStartBackupClicked"
                                    CornerRadius="10" BackgroundColor="#0078D4" TextColor="White" HeightRequest="48" Margin="0,5,0,0"
                                    AutomationProperties.Name="Iniciar backup" AutomationProperties.HelpText="Inicia el proceso de copia de seguridad."/>
                            
                                <Button Text="Cancelar" Command="{Binding CancelBackupCommand}" Clicked="OnCancelBackupClicked" 
                                    IsVisible="{Binding CanCancel}" CornerRadius="10" BackgroundColor="#E81123" TextColor="White" HeightRequest="44"
                                    AutomationProperties.Name="Cancelar backup" AutomationProperties.HelpText="Cancela el proceso en curso."/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Progreso Card -->
                    <Border x:Name="ProgressCard" IsVisible="{Binding IsBusy}" Opacity="0" Scale="0.95"
                            StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                            Padding="22">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="20" Opacity="0.1"/></Border.Shadow>

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <ProgressBar Progress="{Binding GlobalProgress}" ProgressColor="#0078D4" HeightRequest="8" VerticalOptions="Center"
                                             AutomationProperties.Name="Progreso global" AutomationProperties.HelpText="Barra que indica progreso de la copia."/>
                                <Label Grid.Column="1" Text="{Binding PercentageText}" FontFamily="OpenSansSemibold" FontSize="20" TextColor="#0078D4" Margin="10,0,0,0"/>
                            </Grid>
                            
                            <Label Text="{Binding CurrentFileStatus}" FontSize="11" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" LineBreakMode="TailTruncation" HorizontalOptions="Center"/>

                            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="8">
                                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                                    <Label Text="SCAN" FontSize="8" TextColor="Gray" HorizontalTextAlignment="Center"/>
                                    <Label Text="{Binding StatsScanned}" FontSize="14" HorizontalTextAlignment="Center" TextColor="#0078D4"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                                    <Label Text="COPY" FontSize="8" TextColor="Gray" HorizontalTextAlignment="Center"/>
                                    <Label Text="{Binding StatsCopied}" FontSize="14" HorizontalTextAlignment="Center" TextColor="#2DA44E"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                                    <Label Text="SKIP" FontSize="8" TextColor="Gray" HorizontalTextAlignment="Center"/>
                                    <Label Text="{Binding StatsFailed}" FontSize="14" HorizontalTextAlignment="Center" TextColor="#E81123"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Consola de Actividad -->
                    <Border x:Name="ConsoleCard" IsVisible="{Binding ShowActivityLog}" StrokeThickness="0" 
                            BackgroundColor="{AppThemeBinding Light=#121212, Dark=#000000}" 
                            Padding="15" HeightRequest="250">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="LOG DE ACTIVIDAD" FontSize="10" FontAttributes="Bold" TextColor="#4DA6FF" Margin="0,0,0,5"/>
                            <CollectionView ItemsSource="{Binding LogItems}" HeightRequest="200" AutomationProperties.Name="Registro de actividad" AutomationProperties.HelpText="Lista de mensajes de actividad del backup.">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LogEntry">
                                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10" Padding="0,1">
                                            <Label Grid.Column="0" Text="{Binding Timestamp}" TextColor="#666" FontSize="10" FontFamily="Consolas"/>
                                            <Label Grid.Column="1" Text="{Binding Message}" TextColor="{Binding Color}" FontSize="10" FontFamily="Consolas" LineBreakMode="NoWrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

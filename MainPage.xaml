<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LocalBackupMaster.ViewModels"
             xmlns:m="clr-namespace:LocalBackupMaster.Models"
             x:Class="LocalBackupMaster.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Local Backup Master"
             BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#0A0A0A}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" MaximumWidthRequest="720" HorizontalOptions="Center">

            <!-- Header -->
            <Label x:Name="HeaderTitle"
                   Text="Local Backup Master"
                   FontFamily="OpenSansSemibold"
                   FontSize="32"
                   TextColor="{AppThemeBinding Light=#1D1D1F, Dark=#F5F5F7}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,5"
                   Opacity="0" TranslationY="-20" />

            <Label Text="Copia de seguridad local incremental, sin nube."
                   FontSize="14" TextColor="Gray"
                   HorizontalOptions="Center"
                   Opacity="0" x:Name="SubHeaderLabel"
                   Margin="0,0,0,10"/>

            <!-- ══════ Orígenes Card ══════ -->
            <Border x:Name="SourcesCard" Opacity="0" TranslationY="30"
                    StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                    Padding="22">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="📁  Carpetas de Origen" FontFamily="OpenSansSemibold" FontSize="17"
                               TextColor="{AppThemeBinding Light=#222, Dark=#EEE}" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="+ Añadir" FontSize="13" CornerRadius="8"
                                BackgroundColor="#0078D4" TextColor="White" HeightRequest="36"
                                Clicked="OnSelectSourceClicked" x:Name="SelectSourceBtn"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EBEBEB, Dark=#2E2E2E}"/>

                    <!-- Lista de orígenes -->
                    <CollectionView x:Name="SourcesCollectionView" ItemsSource="{Binding SourceItems}"
                                    SelectionMode="None" EmptyView="Sin carpetas de origen.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:BackupSource">
                                <Grid ColumnDefinitions="*, Auto" Padding="0,6">
                                    <Label Grid.Column="0" Text="{Binding Path}" FontSize="13"
                                           TextColor="{AppThemeBinding Light=#444, Dark=#BBB}"
                                           LineBreakMode="TailTruncation" VerticalOptions="Center"/>
                                     <Button Grid.Column="1" Text="✕" FontSize="11" WidthRequest="32" HeightRequest="32"
                                             CornerRadius="6" BackgroundColor="Transparent"
                                             TextColor="Gray" 
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveSourceCommand}"
                                             CommandParameter="{Binding .}"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- ══════ Destinos Card ══════ -->
            <Border x:Name="DestsCard" Opacity="0" TranslationY="30"
                    StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                    Padding="22">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="💾  Destinos de Backup" FontFamily="OpenSansSemibold" FontSize="17"
                               TextColor="{AppThemeBinding Light=#222, Dark=#EEE}" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="+ Añadir" FontSize="13" CornerRadius="8"
                                BackgroundColor="#0078D4" TextColor="White" HeightRequest="36"
                                Clicked="OnSelectDestinationClicked" x:Name="SelectDestinationBtn"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EBEBEB, Dark=#2E2E2E}"/>

                    <!-- Lista de destinos -->
                    <CollectionView x:Name="DestsCollectionView" ItemsSource="{Binding DestinationItems}"
                                    SelectionMode="None" EmptyView="Sin destinos registrados.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:BackupDestination">
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10" Padding="0,6">
                                    <Label Grid.Column="0" Text="💽" FontSize="18" VerticalOptions="Center"/>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                        <Label Text="{Binding BackupPath}" FontSize="13"
                                               TextColor="{AppThemeBinding Light=#444, Dark=#BBB}"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Uuid}" FontSize="10" TextColor="Gray"
                                               LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>
                                     <Button Grid.Column="2" Text="✕" FontSize="11" WidthRequest="32" HeightRequest="32"
                                             CornerRadius="6" BackgroundColor="Transparent"
                                             TextColor="Gray" 
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveDestinationCommand}"
                                             CommandParameter="{Binding .}"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- ══════ Acciones Card ══════ -->
            <Border x:Name="ConfigCard" Opacity="0" TranslationY="30"
                    StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                    Padding="22">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                <VerticalStackLayout Spacing="12">
                    <Label Text="⚡  Opciones de Transferencia" FontFamily="OpenSansSemibold" FontSize="17"
                           TextColor="{AppThemeBinding Light=#222, Dark=#EEE}"/>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EBEBEB, Dark=#2E2E2E}"/>

                    <!-- Paralelismo -->
                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="4" ColumnSpacing="10">
                        <Label Grid.Column="0" Grid.Row="0" Text="Hilos paralelos de copia" FontSize="14"
                               TextColor="{AppThemeBinding Light=#444, Dark=#CCC}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Grid.Row="0" x:Name="ParallelismLabel" Text="{Binding ParallelDegree}"
                               FontFamily="OpenSansSemibold" FontSize="18"
                               TextColor="{AppThemeBinding Light=#0078D4, Dark=#4DA6FF}"
                               VerticalOptions="Center"/>
                        <Slider Grid.Column="0" Grid.Row="1" x:Name="ParallelismSlider"
                                Minimum="1" Maximum="8" Value="{Binding ParallelDegree}"
                                MinimumTrackColor="#0078D4" MaximumTrackColor="LightGray" />
                        <Label Grid.Column="1" Grid.Row="1" Text="hilos" FontSize="11"
                               TextColor="Gray" VerticalOptions="Center"/>
                    </Grid>

                    <!-- Botones -->
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12" Margin="0,8,0,0">
                        <Button Text="🚀  Iniciar Backup" x:Name="StartBackupBtn"
                                Command="{Binding StartBackupCommand}"
                                Clicked="OnStartBackupClicked"
                                CornerRadius="10" BackgroundColor="#0078D4" TextColor="White"
                                FontFamily="OpenSansSemibold" HeightRequest="52" Grid.Column="0"/>

                        <Button Text="Cancelar" x:Name="CancelBackupBtn"
                                Command="{Binding CancelBackupCommand}"
                                Clicked="OnCancelBackupClicked" IsVisible="{Binding CanCancel}"
                                CornerRadius="10" BackgroundColor="#E81123" TextColor="White"
                                FontFamily="OpenSansSemibold" HeightRequest="52"
                                Grid.Column="1" WidthRequest="110"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ══════ Progreso Card ══════ -->
            <Border x:Name="ProgressCard" IsVisible="{Binding IsBusy}" Opacity="0" Scale="0.95"
                    StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                    Padding="22" Margin="0,5,0,15">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="20" Opacity="0.1"/></Border.Shadow>

                <VerticalStackLayout Spacing="14">
                    <Label Text="Transferencia en curso" FontFamily="OpenSansSemibold" FontSize="17"
                           TextColor="{AppThemeBinding Light=#222, Dark=#EEE}"/>

                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="14">
                        <ProgressBar x:Name="GlobalProgressBar" Progress="{Binding GlobalProgress}"
                                     ProgressColor="#0078D4" HeightRequest="10"
                                     VerticalOptions="Center" Grid.Column="0"/>
                        <Label x:Name="PercentageLabel" Text="{Binding PercentageText}"
                               FontFamily="OpenSansSemibold" FontSize="26"
                               TextColor="{AppThemeBinding Light=#0078D4, Dark=#4DA6FF}"
                               Grid.Column="1" VerticalOptions="Center"
                               WidthRequest="68" HorizontalTextAlignment="End"/>
                    </Grid>

                    <Label x:Name="CurrentFileLabel" Text="{Binding CurrentFileStatus}"
                           FontSize="13" TextColor="Gray" HorizontalOptions="Center"/>

                    <!-- Estadísticas rápidas -->
                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                        <Border BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#0D2035}"
                                Padding="10,8" Grid.Column="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="ANALIZADOS" FontSize="9" TextColor="Gray" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                                <Label x:Name="StatsScannedLabel" Text="{Binding StatsScanned}" FontSize="18"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light=#0078D4, Dark=#4DA6FF}"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border BackgroundColor="{AppThemeBinding Light=#F0FFF4, Dark=#0D350D}"
                                Padding="10,8" Grid.Column="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="COPIADOS" FontSize="9" TextColor="Gray" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                                <Label x:Name="StatsCopiedLabel" Text="{Binding StatsCopied}" FontSize="18"
                                       FontFamily="OpenSansSemibold" TextColor="#2DA44E"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border BackgroundColor="{AppThemeBinding Light=#FFF5F5, Dark=#350D0D}"
                                Padding="10,8" Grid.Column="2">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="OMITIDOS" FontSize="9" TextColor="Gray" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                                <Label x:Name="StatsFailedLabel" Text="{Binding StatsFailed}" FontSize="18"
                                       FontFamily="OpenSansSemibold" TextColor="#E81123"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

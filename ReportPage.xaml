<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="LocalBackupMaster.ReportPage"
             Title="Reporte de Backup"
             BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#0A0A0A}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20"
                             MaximumWidthRequest="680" HorizontalOptions="Center">

            <!-- ══ Hero result banner ══ -->
            <Border x:Name="HeroBanner" Opacity="0" TranslationY="20"
                    Padding="28,24" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="Black" Offset="0,6" Radius="20" Opacity="0.12"/></Border.Shadow>

                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="18" RowDefinitions="Auto,Auto,Auto">
                          <Label Grid.Column="0" Grid.RowSpan="3"
                              x:Name="ResultEmojiLabel" Text="{Binding ResultEmoji}"
                              FontSize="52" VerticalOptions="Center"/>

                          <Label Grid.Column="1" Grid.Row="0"
                              x:Name="ResultTitleLabel" Text="{Binding ResultText}"
                              FontFamily="OpenSansSemibold" FontSize="22"
                              TextColor="White"/>

                          <Label Grid.Column="1" Grid.Row="1"
                              x:Name="DurationLabel" Text="{Binding DurationText}"
                              FontSize="14" TextColor="#CCDDFF"/>

                          <Label Grid.Column="1" Grid.Row="2"
                              x:Name="DateLabel" Text="{Binding DateText}"
                              FontSize="12" TextColor="#AABBEE"/>
                </Grid>
            </Border>

            <!-- ══ Stats chips ══ -->
            <Grid x:Name="StatsGrid" Opacity="0" TranslationY="20"
                  ColumnDefinitions="*,*,*,*" ColumnSpacing="10">

                <!-- Analizados -->
                <Border x:Name="ChipScannedBorder" Grid.Column="0" Padding="12,10"
                    StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Offset="0,3" Radius="10" Opacity="0.07"/></Border.Shadow>
                    <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                        <Label Text="📂" FontSize="20" HorizontalTextAlignment="Center"/>
                           <Label x:Name="ChipScanned" Text="{Binding ChipScanned}"
                               FontFamily="OpenSansSemibold" FontSize="22"
                               TextColor="{AppThemeBinding Light=#0078D4, Dark=#4DA6FF}"
                               HorizontalTextAlignment="Center"/>
                           <Label Text="ANALIZADOS" FontSize="9" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                               FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Copiados -->
                <Border x:Name="ChipCopiedBorder" Grid.Column="1" Padding="12,10"
                    StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Offset="0,3" Radius="10" Opacity="0.07"/></Border.Shadow>
                    <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                        <Label Text="📦" FontSize="20" HorizontalTextAlignment="Center"/>
                           <Label x:Name="ChipCopied" Text="{Binding ChipCopied}"
                               FontFamily="OpenSansSemibold" FontSize="22"
                               TextColor="#2DA44E" HorizontalTextAlignment="Center"/>
                           <Label Text="COPIADOS" FontSize="9" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                               FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Tamaño -->
                <Border x:Name="ChipSizeBorder" Grid.Column="2" Padding="12,10"
                    StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Offset="0,3" Radius="10" Opacity="0.07"/></Border.Shadow>
                    <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                        <Label Text="💾" FontSize="20" HorizontalTextAlignment="Center"/>
                           <Label x:Name="ChipSize" Text="{Binding ChipSize}"
                               FontFamily="OpenSansSemibold" FontSize="18"
                               TextColor="#9B59B6" HorizontalTextAlignment="Center"/>
                           <Label Text="COPIADO" FontSize="9" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                               FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Omitidos -->
                <Border x:Name="ChipFailedBorder" Grid.Column="3" Padding="12,10"
                    StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Offset="0,3" Radius="10" Opacity="0.07"/></Border.Shadow>
                    <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                        <Label Text="⚠️" FontSize="20" HorizontalTextAlignment="Center"/>
                           <Label x:Name="ChipFailed" Text="{Binding ChipFailed}"
                               FontFamily="OpenSansSemibold" FontSize="22"
                               TextColor="#E81123" HorizontalTextAlignment="Center"/>
                           <Label Text="OMITIDOS" FontSize="9" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                               FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ══ Archivos con error ══ -->
                <Border x:Name="FailedCard" IsVisible="{Binding FailedCardVisible}" Opacity="0" TranslationY="20"
                    StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                    Padding="22">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                <VerticalStackLayout Spacing="10">
                    <Label Text="⚠️  Archivos omitidos (bloqueados o error)" FontFamily="OpenSansSemibold"
                           FontSize="16" TextColor="{AppThemeBinding Light=#AAA, Dark=#EEE}"/>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EBEBEB, Dark=#2E2E2E}"/>
                    <CollectionView x:Name="FailedList" ItemsSource="{Binding FailedFiles}" SelectionMode="None" AutomationProperties.Name="Archivos omitidos" AutomationProperties.HelpText="Lista de archivos que no se pudieron copiar.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="0,4">
                                    <Label Grid.Column="0" Text="●" TextColor="#E81123"
                                           FontSize="10" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding .}"
                                                           FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                           LineBreakMode="TailTruncation"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- ══ Archivos copiados (expandible) ══ -->
                <Border x:Name="CopiedCard" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}"
                    Padding="0" IsVisible="{Binding CopiedCardVisible}" Opacity="0" TranslationY="20">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="14" Opacity="0.07"/></Border.Shadow>

                <ct:Expander x:Name="CopiedExpander" IsExpanded="False">
                    <ct:Expander.Header>
                        <Grid Padding="22" ColumnDefinitions="*,Auto">
                            <Label Text="📦  Archivos copiados / actualizados" FontFamily="OpenSansSemibold"
                                   FontSize="16" TextColor="{AppThemeBinding Light=#333, Dark=#EEE}"/>
                            <Label Grid.Column="1" x:Name="CopiedCountLabel"
                                   Text="{Binding CopiedCountText}" FontSize="12" TextColor="Gray"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </ct:Expander.Header>

                    <ct:Expander.Content>
                        <VerticalStackLayout Padding="0,0,0,22" Spacing="10">
                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EBEBEB, Dark=#2E2E2E}"/>
                            <CollectionView x:Name="CopiedList" ItemsSource="{Binding CopiedFiles}" SelectionMode="None" AutomationProperties.Name="Archivos copiados" AutomationProperties.HelpText="Lista de archivos copiados o actualizados.">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="0,4">
                                            <Label Grid.Column="0" Text="✓" TextColor="#2DA44E"
                                                   FontSize="11" FontFamily="OpenSansSemibold"
                                                   VerticalOptions="Center"/>
                                             <Label Grid.Column="1" Text="{Binding .}"
                                                 FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                                                   LineBreakMode="TailTruncation"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </ct:Expander.Content>
                </ct:Expander>
            </Border>

            <!-- ══ Botones de acción ══ -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,5,0,20">
                <Button x:Name="BackBtn" Grid.Column="0" Text="← Volver al inicio"
                    Clicked="OnBackClicked"
                    CornerRadius="10" BackgroundColor="#666" TextColor="White"
                    FontFamily="OpenSansSemibold" HeightRequest="50" Opacity="0"
                    AutomationProperties.Name="Volver al inicio" AutomationProperties.HelpText="Regresa a la pantalla principal."/>

                <Button x:Name="ExportBtn" Grid.Column="1" Text="💾 Exportar JSON"
                    Clicked="OnExportClicked"
                    CornerRadius="10" BackgroundColor="#0078D4" TextColor="White"
                    FontFamily="OpenSansSemibold" HeightRequest="50" Opacity="0"
                    AutomationProperties.Name="Exportar reporte" AutomationProperties.HelpText="Exporta el reporte de backup en formato JSON."/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
